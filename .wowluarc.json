{
  "$schema": "https://raw.githubusercontent.com/TradeSkillMaster/wowlua-ls/main/editors/vscode/wowluarc.schema.json",
  "ignore": [
    ".vscode/",
    ".github/",
    "*.md",
    "LICENSE",
    ".gitignore",
    ".pkgmeta"
  ],
  "library": [
    "LibStub/"
  ],
  "framexml": true,
  "flavors": [
    "classic_era",
    "classic",
    "retail"
  ],
  "globals": {
    "read": [
      "LibStub"
    ]
  },
  "diagnostics": {
    "enable": [
      "need-check-nil"
    ]
  }
}